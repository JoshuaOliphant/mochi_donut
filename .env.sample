# Mochi Donut Environment Configuration

# Application Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Claude Agent SDK
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database
DATABASE_URL=sqlite+aiosqlite:///./mochi_donut.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/mochi_donut

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Mochi Integration
MOCHI_API_KEY=your_mochi_api_key_here

# JinaAI Reader API (optional, free tier works without key)
JINA_API_KEY=

# Chroma Vector Database
CHROMA_PERSIST_DIRECTORY=./chroma_data
# For Chroma Cloud:
# CHROMA_HOST=your-instance.chromadb.io
# CHROMA_API_KEY=your_chroma_api_key

# Security
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Rate Limiting
RATE_LIMIT_ENABLED=false
