# Environment Configuration for Mochi Donut
# Copy this file to .env and update the values

# Application Settings
ENVIRONMENT=development
PROJECT_NAME="Mochi Donut"
VERSION="0.1.0"
API_V1_STR="/api/v1"

# Security
SECRET_KEY=your-secret-key-here-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite+aiosqlite:///./mochi_donut.db
REDIS_URL=redis://localhost:6379/0

# API Keys
OPENAI_API_KEY=your-openai-api-key
MOCHI_API_KEY=your-mochi-api-key
JINA_API_KEY=your-jina-api-key

# Chroma Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_API_KEY=

# CORS Configuration
CORS_ORIGINS=["http://localhost:8000","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# AI Model Configuration
AI_CACHING_ENABLED=true
DEFAULT_AI_MODEL=gpt-5-nano
QUALITY_REVIEW_MODEL=gpt-5-standard
PROMPT_GENERATION_MODEL=gpt-5-mini

# Processing Settings
MAX_CONTENT_LENGTH=100000
MIN_PROMPTS_PER_CONTENT=5
MAX_PROMPTS_PER_CONTENT=20
QUALITY_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO