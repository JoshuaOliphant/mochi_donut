# Production Environment Configuration Template for Mochi Donut
# Copy this to .env.production and set actual values
# Secrets should be set via Fly.io secrets, not in environment files

# Application Settings
ENVIRONMENT=production
PROJECT_NAME=Mochi Donut
VERSION=0.1.0
API_V1_STR=/api/v1

# Database Configuration
# Use SQLite with persistent volume in production
DATABASE_URL=sqlite+aiosqlite:///data/mochi_donut.db

# Redis Configuration
# Use Fly Redis or external Redis service
REDIS_URL=redis://fly-mochi-donut-redis.internal:6379/0
REDIS_RESULT_BACKEND=redis://fly-mochi-donut-redis.internal:6379/1

# Chroma Configuration
# Use Chroma Cloud in production
CHROMA_HOST=cloud.trychroma.com
CHROMA_PORT=443
CHROMA_COLLECTION_PREFIX=mochi_donut_prod

# Application Configuration
LOG_LEVEL=INFO
CORS_ORIGINS=["https://mochi-donut.fly.dev","https://app.mochi-donut.com"]

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# AI Model Configuration
AI_CACHING_ENABLED=true
DEFAULT_AI_MODEL=gpt-5-nano
QUALITY_REVIEW_MODEL=gpt-5-standard
PROMPT_GENERATION_MODEL=gpt-5-mini

# AI Model Costs (per 1M tokens, 2025 pricing)
GPT5_NANO_INPUT_COST=0.05
GPT5_NANO_OUTPUT_COST=0.40
GPT5_MINI_INPUT_COST=0.25
GPT5_MINI_OUTPUT_COST=2.00
GPT5_STANDARD_INPUT_COST=1.25
GPT5_STANDARD_OUTPUT_COST=10.00

# Processing Settings
MAX_CONTENT_LENGTH=100000
MIN_PROMPTS_PER_CONTENT=5
MAX_PROMPTS_PER_CONTENT=20
QUALITY_THRESHOLD=0.7

# External Service Configuration
JINA_API_TIMEOUT=30
JINA_CACHE_ENABLED=true
JINA_CACHE_TTL=86400

MOCHI_API_TIMEOUT=30
MOCHI_RATE_LIMIT_DELAY=0.5
MOCHI_MAX_CONCURRENT_REQUESTS=3

CHROMA_TIMEOUT=30
CHROMA_SIMILARITY_THRESHOLD=0.7
CHROMA_MAX_RESULTS=100

# Security Settings
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Secrets (set via flyctl secrets set)
# SECRET_KEY=<set-via-fly-secrets>
# OPENAI_API_KEY=<set-via-fly-secrets>
# MOCHI_API_KEY=<set-via-fly-secrets>
# JINA_API_KEY=<set-via-fly-secrets>
# CHROMA_API_KEY=<set-via-fly-secrets>