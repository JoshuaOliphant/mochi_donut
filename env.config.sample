# Environment Configuration for Mochi Donut
# Copy this to .env and update with your actual values

# Application Environment
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
# For development with Docker
DATABASE_URL=postgresql://mochi_user:dev_password@localhost:5432/mochi_donut
# For development with SQLite
# DATABASE_URL=sqlite:///./mochi_donut.db

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_RESULT_BACKEND=redis://redis:6379/1

# Chroma Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=mochi_donut
# For production with Chroma Cloud
# CHROMA_API_KEY=your-chroma-cloud-api-key
# CHROMA_TENANT=your-tenant-id
# CHROMA_DATABASE=your-database-name

# AI API Keys
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# External API Keys
MOCHI_API_KEY=your-mochi-api-key
JINA_API_KEY=your-jina-api-key

# Celery Configuration
CELERY_LOG_LEVEL=INFO
CELERY_WORKER_CONCURRENCY=4
CELERY_MAX_TASKS_PER_CHILD=1000

# Task Queue Rate Limits (requests per minute)
CONTENT_PROCESSING_RATE_LIMIT=10
AI_PROCESSING_RATE_LIMIT=5
EXTERNAL_API_RATE_LIMIT=20
MAINTENANCE_RATE_LIMIT=2

# Monitoring and Logging
LOGFIRE_TOKEN=your-logfire-token
PROMETHEUS_ENABLED=false

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true

# Production Security Settings (only for production)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0

# File Storage Configuration
STORAGE_TYPE=local
# For S3-compatible storage
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_ENDPOINT_URL=https://your-s3-endpoint.com